# ── Variables de entorno para los scripts de tools/ ──
# Copiar como .env y completar con valores reales
# Cargar con: export $(grep -v '^#' tools/.env | xargs)

# API-Football
API_FOOTBALL_KEY=tu_api_key_aqui

# Base de datos local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mundial
DB_USER=postgres
DB_PASS=tu_password_local

# Base de datos Railway (producción)
RAILWAY_DB_HOST=tu_host_railway
RAILWAY_DB_PORT=tu_puerto
RAILWAY_DB_NAME=railway
RAILWAY_DB_USER=postgres
RAILWAY_DB_PASS=tu_password_railway

# ── HeyGen API (heygen_generate.py / heygen_webhook.py) ──
# Obtener en: https://app.heygen.com/settings → API
HEYGEN_API_KEY=tu_heygen_api_key

# Avatar ID — obtenelo desde GET https://api.heygen.com/v2/avatars
# Ejemplo: "Angela-inblackskirt-20220820" o tu avatar custom
HEYGEN_AVATAR_ID=tu_avatar_id

# Voice ID en español — obtenelo desde GET https://api.heygen.com/v2/voices
# Opciones recomendadas:
#   es-MX-DaliaNeural     ← español mexicano (femenino)
#   es-AR-TomasNeural     ← español argentino (masculino)
#   es-ES-AlvaroNeural    ← español neutro (masculino)
HEYGEN_VOICE_ID=es-AR-TomasNeural

# Secret para verificar firmas del webhook (configurar en HeyGen dashboard)
HEYGEN_WEBHOOK_SECRET=tu_webhook_secret_opcional

# Directorio donde se guardan los .mp4 descargados por el webhook
HEYGEN_DOWNLOAD_DIR=output/videos

# Puerto del servidor webhook local
WEBHOOK_PORT=5050
